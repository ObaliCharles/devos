# ---- Database -------------------------------------------------------------
# Local:  mongodb://127.0.0.1:27017/developeros
# Atlas:  mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/developeros
MONGODB_URI=mongodb://127.0.0.1:27017/developeros

# ---- Auth (Clerk) ---------------------------------------------------------
# Get these from https://dashboard.clerk.com -> your app -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ---- AI (optional) --------------------------------------------------------
# Two providers, tried in order. With neither set, the AI surface still loads
# but returns a "not configured" note instead of an answer.
#
# Anthropic is the intended provider and needs billing enabled on the account.
ANTHROPIC_API_KEY=

# Groq is the fallback, used automatically whenever an Anthropic call fails
# before it has streamed any text — which is exactly what an unbilled key looks
# like. Free key from https://console.groq.com/keys. Handy for testing the app
# end to end without spending anything.
GROQ_API_KEY=
# Optional. Defaults to llama-3.3-70b-versatile.
GROQ_MODEL=
